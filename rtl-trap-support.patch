             idex_funct3 <= id_funct3;
-            idex_is_csr <= id_is_csr; idex_sys_ecall <= id_sys_ecall; idex_sys_ebreak <= id_sys_ebreak; idex_sys_mret <= id_sys_mret; idex_csr_addr <= ifid_instr[31:20];
+            idex_is_csr <= id_is_csr; idex_sys_ecall <= id_sys_ecall; idex_sys_ebreak <= id_sys_ebreak; idex_sys_mret <= id_sys_mret; idex_illegal <= id_illegal; idex_csr_addr <= ifid_instr[31:20];
         end
     end
 
@@ -249,12 +251,34 @@ module riscv_core_pipe #(
     wire        csr_wr    = idex_is_csr & ((csr_op == 2'b01) | (idex_rs1 != 5'b0));
 
     // detectare trap / mret (gate cu ~mul_stall: o singura instr in EX)
-    wire        csr_illegal = idex_is_csr & ~csr_addr_valid;
-    wire        ex_trap = (idex_sys_ecall | idex_sys_ebreak | csr_illegal) & ~mul_stall;
+    wire        csr_illegal = (idex_is_csr & ~csr_addr_valid) | idex_illegal;
+
+    // ---- exceptii de adresa nealiniata (rezolvate in EX) ----
+    // tinta transferului de control (branch/JAL: pc+imm; JALR: (rs1+imm)&~1)
+    wire [31:0] ex_ctrl_target   = (idex_jump & idex_jalr) ? ex_jalr_target : ex_pc_target;
+    wire        ex_ctrl_transfer = ex_branch_taken | idex_jump;
+    // IALIGN=32 (fara extensia C): tinta trebuie aliniata la 4
+    wire        ex_fetch_misal   = ex_ctrl_transfer & (|ex_ctrl_target[1:0]);
+    // LH/LHU/SH: adresa para; LW/SW: adresa multiplu de 4 (funct3[1:0]: 01=half, 10=word)
+    wire        ex_addr_misal    = (idex_funct3[1:0] == 2'b01 &  ex_alu_result[0])
+                                 | (idex_funct3[1:0] == 2'b10 & |ex_alu_result[1:0]);
+    wire        ex_load_misal    = idex_mem_read  & ex_addr_misal;
+    wire        ex_store_misal   = idex_mem_write & ex_addr_misal;
+
+    wire        ex_trap = (idex_sys_ecall | idex_sys_ebreak | csr_illegal |
+                           ex_fetch_misal | ex_load_misal | ex_store_misal) & ~mul_stall;
     wire        ex_mret =  idex_sys_mret & ~mul_stall;
     wire [31:0] ex_trap_cause = idex_sys_ecall  ? `CAUSE_ECALL_M
-                              : idex_sys_ebreak  ? `CAUSE_BREAKPOINT
-                              :                    `CAUSE_ILLEGAL;
+                              : idex_sys_ebreak ? `CAUSE_BREAKPOINT
+                              : csr_illegal     ? `CAUSE_ILLEGAL
+                              : ex_fetch_misal  ? `CAUSE_MISALIGNED_FETCH
+                              : ex_load_misal   ? `CAUSE_MISALIGNED_LOAD
+                              :                   `CAUSE_MISALIGNED_STORE;
+    // mtval: PC pentru EBREAK, adresa vinovata pentru exceptiile de aliniere
+    wire [31:0] ex_trap_val   = idex_sys_ebreak ? idex_pc
+                              : ex_fetch_misal  ? ex_ctrl_target
+                              : (ex_load_misal | ex_store_misal) ? ex_alu_result
+                              :                   32'b0;
 
     csr u_csr (
         .clk(clk), .rst_n(rst_n),
@@ -262,7 +286,7 @@ module riscv_core_pipe #(
         .addr(idex_csr_addr), .wdata(csr_wval),
         .rdata(csr_rdata), .addr_valid(csr_addr_valid),
         .trap_en(ex_trap), .trap_cause(ex_trap_cause),
-        .trap_epc(idex_pc), .trap_val(32'b0), .mret_en(ex_mret),
+        .trap_epc(idex_pc), .trap_val(ex_trap_val), .mret_en(ex_mret),
         .mtvec_o(csr_mtvec), .mepc_o(csr_mepc)
     );
 
diff --git a/rtl/riscv_defs.vh b/rtl/riscv_defs.vh
index 4f43718..f0ed93a 100644
--- a/rtl/riscv_defs.vh
+++ b/rtl/riscv_defs.vh
@@ -140,6 +140,9 @@
 `define CAUSE_ILLEGAL    32'd2
 `define CAUSE_BREAKPOINT 32'd3
 `define CAUSE_ECALL_M    32'd11
+`define CAUSE_MISALIGNED_FETCH 32'd0   // instruction address misaligned (branch/jump target)
+`define CAUSE_MISALIGNED_LOAD  32'd4   // load address misaligned
+`define CAUSE_MISALIGNED_STORE 32'd6   // store/AMO address misaligned
 
