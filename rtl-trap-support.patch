diff --git a/rtl/control.v b/rtl/control.v
index 8296eb7..a5b1241 100644
--- a/rtl/control.v
+++ b/rtl/control.v
@@ -23,7 +23,8 @@ module control (
     output reg                   is_csr,       // instructiune CSR (Zicsr)
     output reg                   sys_ecall,    // ECALL  -> trap
     output reg                   sys_ebreak,   // EBREAK -> trap
-    output reg                   sys_mret      // MRET   -> revenire din trap
+    output reg                   sys_mret,     // MRET   -> revenire din trap
+    output reg                   illegal       // opcode necunoscut -> trap (cauza 2)
 );
 
     // --- decodarea operatiei ALU pentru R-type / OP-IMM ---
@@ -60,6 +61,7 @@ module control (
         sys_ecall = 1'b0;
         sys_ebreak= 1'b0;
         sys_mret  = 1'b0;
+        illegal   = 1'b0;
 
         case (opcode)
             // ---- R-type: rd = rs1 op rs2 (sau extensia M) ----
@@ -157,7 +159,10 @@ module control (
                 end
             end
 
-            default: ;
+            // ---- MISC-MEM: FENCE / FENCE.I (NOP pe acest model de memorie) ----
+            `OPC_MISC_MEM: ;
+
+            default: illegal = 1'b1;   // instructiune ilegala -> trap in EX
         endcase
     end
 
